# Microsoft Entra ID (Azure AD) Authentication for Storybook
# Register a Single-Page Application in the Azure Portal and add these redirect URIs:
#   https://iamitesh.github.io/lit-atoms/
#   http://localhost:6006/
STORYBOOK_ENTRA_CLIENT_ID=your-entra-client-id-here
STORYBOOK_ENTRA_TENANT_ID=your-entra-tenant-id-here

# Figma API Configuration
# Get your personal access token from: https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=your-figma-access-token-here

# Figma File Key
# Extract from your Figma URL: https://www.figma.com/file/[FILE_KEY]/...
FIGMA_FILE_KEY=your-figma-file-key-here
